<div class="standard-form">
    <div class="standard-form scrollable">
        <nav class="sheet-tabs tabs" style="flex: none;">
            <a class="item active" data-action="tab" data-group="primary" data-tab="coreRolls">
                <span>
                    <i class="fa-solid fa-dice-d20"></i>
                    {{localize "CUSTOM_ROLLS.coreRolls"}}
                </span>
            </a>
            <a class="item" data-action="tab" data-group="primary" data-tab="weaponTypes">
                <span>
                    <i class="fa-solid fa-sword"></i>
                    {{localize "CUSTOM_ROLLS.weaponTypes"}}
                </span>
            </a>
        </nav>
        <section class="tab active" data-group="primary" data-tab="coreRolls">
            <fieldset>
                <legend>{{localize "CUSTOM_ROLLS.abilityCheck"}}</legend>
                <div class="form-group">
                    <label>{{localize "CUSTOM_ROLLS.die"}}</label>
                    <div class="form-fields">
                        <input id="custom-rolls-ability-die" name="rolls.ability.die" type="text" value="{{rolls.ability.die}}"> 
                    </div>
                </div>
                <div class="form-group">
                    <label>{{localize "CUSTOM_ROLLS.rollMode"}}</label>
                    <div class="form-fields">
                        <select id="custom-rolls-ability-roll-mode" name="rolls.ability.rollMode">
                            {{selectOptions selects.rollMode.choices selected=rolls.ability.rollMode localize=true}}
                        </select>
                    </div>
                </div>
            </fieldset>
            <fieldset>
                <legend>{{localize "CUSTOM_ROLLS.attackRoll"}}</legend>
                <div class="form-group">
                    <label>{{localize "CUSTOM_ROLLS.die"}}</label>
                    <div class="form-fields">
                        <input id="custom-rolls-attack-die" name="rolls.attack.die" type="text" value="{{rolls.attack.die}}"> 
                    </div>
                </div>
                <div class="form-group">
                    <label>{{localize "CUSTOM_ROLLS.rollMode"}}</label>
                    <div class="form-fields">
                        <select id="custom-rolls-attack-roll-mode" name="rolls.attack.rollMode">
                            {{selectOptions selects.rollMode.choices selected=rolls.attack.rollMode localize=true}}
                        </select>
                    </div>
                </div>
                <div class="form-group">
                    <label>{{localize "CUSTOM_ROLLS.criticalHitRule"}}</label>
                    <div class="form-fields">
                        <select id="custom-rolls-attack-critical-rule" name="rolls.attack.criticalRule">
                            {{selectOptions selects.criticalRule.choices selected=rolls.attack.criticalRule localize=true}}
                        </select>
                    </div>
                </div>
                <div class="form-group" data-critical-lower-bound-group>
                    <label>{{localize "CUSTOM_ROLLS.criticalHitLowerBound"}}</label>
                    <div class="form-fields">
                        <select id="custom-rolls-attack-critical-lower-bound" name="rolls.attack.criticalLowerBound">
                            {{selectOptions selects.criticalLowerBound.choices selected=rolls.attack.criticalLowerBound}}
                        </select>
                    </div>
                </div>
            </fieldset>
            <fieldset>
                <legend>{{localize "CUSTOM_ROLLS.concentrationSavingThrow"}}</legend>
                <div class="form-group">
                    <label>{{localize "CUSTOM_ROLLS.die"}}</label>
                    <div class="form-fields">
                        <input id="custom-rolls-concentration-die" name="rolls.concentration.die" type="text" value="{{rolls.concentration.die}}"> 
                    </div>
                </div>
                <div class="form-group">
                    <label>{{localize "CUSTOM_ROLLS.rollMode"}}</label>
                    <div class="form-fields">
                        <select id="custom-rolls-concentration-roll-mode" name="rolls.concentration.rollMode">
                            {{selectOptions selects.rollMode.choices selected=rolls.concentration.rollMode localize=true}}
                        </select>
                    </div>
                </div>
            </fieldset>
            <fieldset>
                <legend>{{localize "CUSTOM_ROLLS.initiativeRoll"}}</legend>
                <div class="form-group">
                    <label>{{localize "CUSTOM_ROLLS.die"}}</label>
                    <div class="form-fields">
                        <input id="custom-rolls-initiative-die" name="rolls.initiative.die" type="text" value="{{rolls.initiative.die}}"> 
                    </div>
                </div>
                <div class="form-group">
                    <label>{{localize "CUSTOM_ROLLS.rollMode"}}</label>
                    <div class="form-fields">
                        <select id="custom-rolls-initiative-roll-mode" name="rolls.initiative.rollMode">
                            {{selectOptions selects.rollMode.choices selected=rolls.initiative.rollMode localize=true}}
                        </select> 
                    </div>
                </div>
            </fieldset>
            <fieldset>
                <legend>{{localize "CUSTOM_ROLLS.savingThrow"}}</legend>
                <div class="form-group">
                    <label>{{localize "CUSTOM_ROLLS.die"}}</label>
                    <div class="form-fields">
                        <input id="custom-rolls-saving-throw-die" name="rolls.savingThrow.die" type="text" value="{{rolls.savingThrow.die}}"> 
                    </div>
                </div>
                <div class="form-group">
                    <label>{{localize "CUSTOM_ROLLS.rollMode"}}</label>
                    <div class="form-fields">
                        <select id="custom-rolls-saving-throw-roll-mode" name="rolls.savingThrow.rollMode">
                            {{selectOptions selects.rollMode.choices selected=rolls.savingThrow.rollMode localize=true}}
                        </select> 
                    </div>
                </div>
            </fieldset>
            <fieldset>
                <legend>{{localize "CUSTOM_ROLLS.skillCheck"}}</legend>
                <div class="form-group">
                    <label>{{localize "CUSTOM_ROLLS.die"}}</label>
                    <div class="form-fields">
                        <input id="custom-rolls-skill-die" name="rolls.skill.die" type="text" value="{{rolls.skill.die}}"> 
                    </div>
                </div>
                <div class="form-group">
                    <label>{{localize "CUSTOM_ROLLS.rollMode"}}</label>
                    <div class="form-fields">
                        <select id="custom-rolls-skill-roll-mode" name="rolls.skill.rollMode">
                            {{selectOptions selects.rollMode.choices selected=rolls.skill.rollMode localize=true}}
                        </select>
                    </div>
                </div>
            </fieldset>
            <fieldset>
                <legend>{{localize "CUSTOM_ROLLS.toolCheck"}}</legend>
                <div class="form-group">
                    <label>{{localize "CUSTOM_ROLLS.die"}}</label>
                    <div class="form-fields">
                        <input id="custom-rolls-tool-die" name="rolls.tool.die" type="text" value="{{rolls.tool.die}}"> 
                    </div>
                </div>
                <div class="form-group">
                    <label>{{localize "CUSTOM_ROLLS.rollMode"}}</label>
                    <div class="form-fields">
                        <select id="custom-rolls-tool-roll-mode" name="rolls.tool.rollMode">
                            {{selectOptions selects.rollMode.choices selected=rolls.tool.rollMode localize=true}}
                        </select>
                    </div>
                </div>
            </fieldset>
        </section>
        <section class="tab" data-group="primary" data-tab="weaponTypes">
            {{#each rolls.weaponTypes as |weaponType key|}}
            <fieldset>
                <legend>{{label}}</legend>
                <div class="form-group">
                    <label>{{localize "CUSTOM_ROLLS.die"}}</label>
                    <div class="form-fields">
                        <input id="custom-rolls-die" name="rolls.weaponTypes.{{key}}.die" type="text" value="{{die}}"> 
                    </div>
                </div>
                <div class="form-group">
                    <label>{{localize "CUSTOM_ROLLS.rollMode"}}</label>
                    <div class="form-fields">
                        <select id="custom-rolls-roll-mode" name="rolls.weaponTypes.{{key}}.rollMode">
                            {{selectOptions ../selects.rollMode.choices selected=rollMode localize=true}}
                        </select>
                    </div>
                </div>
                <div class="form-group">
                    <label>{{localize "CUSTOM_ROLLS.criticalHitRule"}}</label>
                    <div class="form-fields">
                        <select id="custom-rolls-critical-rule" name="rolls.weaponTypes.{{key}}.criticalRule">
                            {{selectOptions ../selects.criticalRule.choices selected=criticalRule localize=true}}
                        </select>
                    </div>
                </div>
                <div class="form-group" data-critical-lower-bound-group>
                    <label>{{localize "CUSTOM_ROLLS.criticalHitLowerBound"}}</label>
                    <div class="form-fields">
                        <select id="custom-rolls-critical-lower-bound" name="rolls.weaponTypes.{{key}}.criticalLowerBound">
                            {{selectOptions ../selects.criticalLowerBound.choices selected=criticalLowerBound}}
                        </select>
                    </div>
                </div>
            </fieldset>
            {{/each}}
        </section>  
    </div>
    <footer class="form-footer" data-application-part="footer">
        <button type="submit" class="save-button">
            <i class="fas fa-solid fa-floppy-disk"></i>{{localize "CUSTOM_ROLLS.form.button.save.label"}}
        </button>
    </footer>
</div>
